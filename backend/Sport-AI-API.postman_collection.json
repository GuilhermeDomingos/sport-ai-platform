                  "});",
                  "",
                  "pm.test(\"Video foi encontrado\", function () {",
                  "    pm.expect(pm.response.json().exists).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ]
