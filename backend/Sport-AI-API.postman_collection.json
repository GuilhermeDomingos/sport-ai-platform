        {
          "name": "Process Video",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/process",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "videos",
                "{{videoId}}",
                "process"
              ]
            },
            "description": "Processa o ultimo video enviado e extrai metadados reais com OpenCV."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Processamento retorna 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Processamento retorna metadados tecnicos\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql(\"processed\");",
                  "    pm.expect(body.metadata).to.have.property(\"fps\");",
                  "    pm.expect(body.metadata).to.have.property(\"totalFrames\");",
                  "    pm.expect(body.metadata).to.have.property(\"durationSeconds\");",
                  "    pm.expect(body.metadata).to.have.property(\"resolution\");",
                  "    pm.expect(body.metadata).to.have.property(\"fileSizeMb\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ]
        },
