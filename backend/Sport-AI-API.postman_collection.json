        {
          "name": "Extract Frames",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/frames/extract?interval_seconds=0.5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "videos",
                "{{videoId}}",
                "frames",
                "extract"
              ],
              "query": [
                {
                  "key": "interval_seconds",
                  "value": "0.5"
                }
              ]
            },
            "description": "Extrai frames JPEG do ultimo video enviado a cada 0.5 segundos."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Extracao retorna 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Frames foram extraidos\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql(\"frames_extracted\");",
                  "    pm.expect(body.frameIntervalSeconds).to.eql(0.5);",
                  "    pm.expect(body.totalFramesExtracted).to.be.above(0);",
                  "    pm.expect(body.frames.length).to.eql(body.totalFramesExtracted);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ]
        },
